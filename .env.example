# .env.example
FIRECRAWL_API_KEY=fc-your-key-here
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-key-here

# Optional: override the Gemini model (default: gemini-3.5-flash).
# Other current options: gemini-3-flash-preview, gemini-3.1-flash-lite
# GEMINI_MODEL=gemini-3.5-flash

# Optional: a second model tried only if GEMINI_MODEL fails (e.g. "high demand" 503).
# Set to a known-good, ideally different, model so a spike doesn't drop extraction.
# GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite

# PostHog analytics — create a free project at posthog.com.
# Without these, analytics is a silent no-op (fine for local dev).
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-key-here
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
